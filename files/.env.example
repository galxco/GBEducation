# Banco de dados PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/gbeducation?schema=public"

# JWT
JWT_SECRET="sua-chave-secreta-aqui-minimo-32-caracteres"
JWT_REFRESH_SECRET="sua-chave-refresh-diferente-aqui"

# Servidor
PORT=3333
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
